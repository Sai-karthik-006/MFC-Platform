generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH_ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

model Category {
  id            String    @id @default(uuid()) @db.Uuid
  name          String    @unique
  slug          String    @unique
  description   String?
  icon          String?
  bannerImage   String?
  displayOrder  Int       @default(0)
  isActive      Boolean   @default(true)
  products      Product[]
  createdAt     DateTime  @default(now()) @db.Timestamp
  updatedAt     DateTime  @updatedAt @db.Timestamp

  @@index([slug])
}

model Product {
  id              String           @id @default(uuid()) @db.Uuid
  categoryId      String           @db.Uuid
  name            String
  slug            String           @unique
  description     String?
  thumbnailImage  String?
  isVeg           Boolean          @default(false)
  isFeatured      Boolean          @default(false)
  isAvailable     Boolean          @default(true)
  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  variants        ProductVariant[]
  images          ProductImage[]
  createdAt       DateTime         @default(now()) @db.Timestamp
  updatedAt       DateTime         @updatedAt @db.Timestamp

  @@index([categoryId])
  @@index([slug])
  @@index([name])
}

model ProductVariant {
  id          String      @id @default(uuid()) @db.Uuid
  productId   String      @db.Uuid
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  name        String
  price       Decimal     @db.Decimal(10, 2)
  sku         String      @unique
  stock       Int         @default(0)
  isDefault   Boolean     @default(false)
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now()) @db.Timestamp
  updatedAt   DateTime    @updatedAt @db.Timestamp

  @@index([productId])
  @@index([sku])
}

model ProductImage {
  id          String    @id @default(uuid()) @db.Uuid
  productId   String    @db.Uuid
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl    String
  altText     String?
  sortOrder   Int       @default(0)
  isPrimary   Boolean   @default(false)
  createdAt   DateTime  @default(now()) @db.Timestamp

  @@index([productId])
}

model Order {
  id              String         @id @default(uuid()) @db.Uuid
  orderNumber     String         @unique @db.VarChar(50)
  customerName    String         @db.VarChar(100)
  customerPhone   String         @db.VarChar(20)
  customerEmail   String?        @db.VarChar(255)
  customerAddress String
  landmark        String?
  notes           String?
  subtotal        Decimal        @db.Decimal(10, 2)
  deliveryCharge  Decimal        @db.Decimal(10, 2)
  discount        Decimal        @db.Decimal(10, 2)
  totalAmount     Decimal        @db.Decimal(10, 2)
  orderStatus     OrderStatus    @default(PENDING)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus
  items           OrderItem[]
  payment         Payment?
  notifications   Notification[] @relation("NotificationOrder")
  createdAt       DateTime       @default(now()) @db.Timestamp
  updatedAt       DateTime       @updatedAt @db.Timestamp

  @@index([orderStatus])
  @@index([customerEmail])
  @@index([orderNumber])
}

model OrderItem {
  id               String         @id @default(uuid()) @db.Uuid
  orderId          String         @db.Uuid
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariantId String         @db.Uuid
  variant          ProductVariant @relation(fields: [productVariantId], references: [id])
  productName      String
  variantName      String
  unitPrice        Decimal        @db.Decimal(10, 2)
  quantity         Int
  total            Decimal        @db.Decimal(10, 2)
  createdAt        DateTime       @default(now()) @db.Timestamp

  @@index([orderId])
  @@index([productVariantId])
}

model Payment {
  id                 String        @id @default(uuid()) @db.Uuid
  orderId            String        @db.Uuid @unique
  order              Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method             PaymentMethod
  status             PaymentStatus
  amount             Decimal       @db.Decimal(10, 2)
  transactionReference String?
  paidAt             DateTime?
  createdAt          DateTime      @default(now()) @db.Timestamp

  @@index([orderId])
}

enum UserRole {
  CUSTOMER
  ADMIN
  DELIVERY
}

model User {
  id           String        @id @default(uuid()) @db.Uuid
  email        String        @unique @db.VarChar(255)
  password     String        @db.VarChar(255)
  name         String        @db.VarChar(100)
  phone        String?       @db.VarChar(20)
  role         UserRole      @default(CUSTOMER)
  notifications Notification[] @relation("UserNotifications")
  createdAt    DateTime      @default(now()) @db.Timestamp
  updatedAt    DateTime      @updatedAt @db.Timestamp

  @@index([role])
}

model CateringRequest {
  id              String   @id @default(uuid()) @db.Uuid
  customerName    String
  phone           String
  email           String?
  eventType       String   @db.VarChar(100)
  eventDate       DateTime @db.Timestamp
  guestCount      Int
  message         String?
  status          String
  notifications   Notification[] @relation("NotificationCatering")
  createdAt       DateTime @default(now()) @db.Timestamp
  updatedAt       DateTime @updatedAt @db.Timestamp
}

enum NotificationType {
  ORDER_CONFIRMED
  ORDER_PREPARING
  ORDER_PICKED_UP
  ORDER_DELIVERED
  NEW_CATERING_REQUEST
  NEW_ORDER_ASSIGNED
}

model Notification {
  id          String         @id @default(uuid()) @db.Uuid
  userId      String         @db.Uuid
  user        User           @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  message     String
  orderId     String?        @db.Uuid
  order       Order?         @relation("NotificationOrder", fields: [orderId], references: [id])
  cateringId  String?        @db.Uuid
  catering    CateringRequest? @relation("NotificationCatering", fields: [cateringId], references: [id])
  isRead      Boolean        @default(false)
  createdAt   DateTime       @default(now()) @db.Timestamp

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}